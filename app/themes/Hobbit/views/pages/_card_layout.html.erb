<%# app/themes/Hobbit/views/pages/_card_layout.html.erb %>
<div id="bingo_card_container" class="bingo-container">
  <% if game.status == 'ended' && game.winner %>
    <div class="victory-banner">
      <h2>🏆 WINNER: <%= game.winner.username %> 🏆</h2>
      <p>Game ended at <%= game.ended_at.strftime("%I:%M %p") %></p>
    </div>
  <% end %>

  <div id="flash-messages"></div>

  <header class="game-header">


    <% if game.status == 'active' %>
      <div class="win-action-container">
        <% is_pending = PendingAction.exists?(user: card.user, action_type: 'claim_win', status: 'pending') %>
        
        <%= button_to "call bingo!", claim_win_bingo_card_path(card), 
              method: :post,
              class: "btn-call-bingo",
              disabled: is_pending %>
        
        <% if is_pending %>
          <p class="pending-text">Admin is verifying your win...</p>
        <% end %>
      </div>
    <% end %>
  </header>

  <%# We need to re-group cells here because this partial might be called from a model %>
  <% grouped_cells = card.bingo_cells.includes(:bingo_item).order(:id).group_by { |c| c.bingo_item.column_letter } %>
<% columns = ["B", "I", "N", "G", "O"].first(game.size) %>

  <div class="bingo-grid size-<%= game.size %>">
    <% columns.each do |letter| %>
      <div class="grid-header">
      <% if letter == "O" %>
<%= image_tag "hobbit_hole.png", alt: "Hobbit Hole", class: "grid-header-icon" %>
      <% else %>
<%= letter %>
      <% end %>
      </div>
    <% end %>
    

    <% (0...game.size).each do |row_index| %>
      <% columns.each do |letter| %>
            
        <% cell = grouped_cells[letter]&.at(row_index) %>
        <% if cell %>
<%= render "Hobbit/views/pages/cell", cell: cell %>
        <% else %>
          <div class="bingo-cell empty"></div>
        <% end %>
      <% end %>
    <% end %>
  </div>


  <%= render "Hobbit/views/pages/replacement_section", card: card, game: game %>

<div class="header-main text-center mt-4 px-2">
  <h1 class="leading-tight break-words text-2xl sm:text-3xl md:text-5xl">
    <%= game.title %>
  </h1>
  <p class="mt-1 text-sm sm:text-base">
    Status: <span class="badge"><%= game.status %></span>
  </p>
</div>

</div>