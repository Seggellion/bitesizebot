<div class="min-h-screen bg-slate-950 text-slate-200 p-6 font-sans">
<%= render '/shared/header' %>

  <div class="max-w-7xl mx-auto">
    
    <header class="mb-8 flex justify-between items-end">
      <div>
        <h1 class="text-3xl font-bold text-white tracking-tight">Financial Dashboard</h1>
        <p class="text-slate-400">Analysis for <%= @user.username %></p>
      </div>
      <div class="text-right">
        <span class="text-xs font-mono uppercase tracking-widest text-slate-500">System Status</span>
        <div class="text-emerald-400 flex items-center gap-2">
          <div class="h-2 w-2 bg-emerald-400 rounded-full animate-pulse"></div>
          Live Data Feed
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
        <div class="text-slate-500 text-sm font-medium uppercase">Total Ledger Balance</div>
        <div class="text-2xl font-mono text-white mt-1">$<%= number_with_precision(@total_balance, precision: 2) %></div>
      </div>
      <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
        <div class="text-slate-500 text-sm font-medium uppercase">Active Investments</div>
        <div class="text-2xl font-mono text-blue-400 mt-1"><%= @active_investments %></div>
      </div>
      <div class="bg-slate-900 border border-slate-800 p-5 rounded-xl">
        <div class="text-slate-500 text-sm font-medium uppercase">Raffle Participations</div>
        <div class="text-2xl font-mono text-purple-400 mt-1"><%= @giveaway_entries.count %></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <div class="lg:col-span-2 bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-800 flex justify-between items-center">
          <h2 class="text-lg font-semibold text-white">Ledger History</h2>
          <button class="text-xs bg-slate-800 hover:bg-slate-700 px-3 py-1 rounded text-slate-300 transition">Export CSV</button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-950/50 text-slate-500 text-xs uppercase">
                <th class="px-6 py-3 font-medium">Timestamp</th>
                <th class="px-6 py-3 font-medium">Type</th>
                <th class="px-6 py-3 font-medium">Amount</th>
                <th class="px-6 py-3 font-medium">Metadata</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
              <% @ledger_entries.each do |entry| %>
                <tr class="hover:bg-slate-800/30 transition-colors">
                  <td class="px-6 py-4 text-sm font-mono"><%= entry.created_at.strftime("%Y-%m-%d %H:%M") %></td>
                  <td class="px-6 py-4">
                    <span class="px-2 py-1 rounded-md text-xs font-semibold <%= entry.entry_type == 'credit' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-red-500/10 text-red-400' %>">
                      <%= entry.entry_type.upcase %>
                    </span>
                  </td>
                  <td class="px-6 py-4 font-mono text-sm text-white"><%= number_to_currency(entry.amount) %></td>
                  <td class="px-6 py-4 text-xs text-slate-500"><%= entry.metadata.to_json.truncate(30) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="space-y-8">
        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">Portfolio</h2>
          <div class="space-y-4">
            <% @investments.each do |inv| %>
              <div class="flex justify-between items-center p-3 bg-slate-950 rounded-lg border border-slate-800">
                <div>
                  <div class="text-sm font-bold text-slate-200"><%= inv.investment_name %></div>
                  <div class="text-xs text-slate-500">Rate: <%= number_to_percentage(inv.interest_rate * 100, precision: 2) %></div>
                </div>
                <div class="text-right font-mono text-sm text-blue-400">
                  $<%= inv.amount %>
                </div>
              </div>
            <% end %>
          </div>
        </section>

        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">Raffle Entries</h2>
          <div class="space-y-3">
            <% @giveaway_entries.each do |entry| %>
              <div class="flex items-center gap-3 text-sm">
                <div class="h-8 w-8 rounded bg-purple-500/20 flex items-center justify-center text-purple-400">
                  🎟
                </div>
                <div>
                  <div class="text-slate-300 font-medium">Entry #<%= entry.id %></div>
                  <div class="text-xs text-slate-500"><%= entry.tickets_count %> tickets held</div>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      </div>

    </div>
  </div>
</div>