<%# Local variables: inv (the investment object) %>
<tr class="hover:bg-slate-800/30 transition group border-b border-slate-800/50">
  <td class="px-4 py-4">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-slate-800 flex items-center justify-center font-bold text-purple-400 text-xs border border-slate-700">
        <%= inv.ticker.symbol[0..1] %>
      </div>
      <div class="flex flex-col">
        <div class="flex items-center gap-2">
          <span class="font-bold text-slate-200 group-hover:text-purple-400 transition"><%= inv.ticker.symbol %></span>
          <% if inv.pending_purchase? %>
            <span class="text-[9px] bg-blue-500/20 text-blue-400 px-1 rounded border border-blue-500/30 font-bold">BUYING</span>
          <% end %>
        </div>
        <span class="text-[10px] text-slate-500 uppercase tracking-tighter">
          <% if inv.purchase_price.to_f > 0 %>
            Avg: ƒ<%= number_with_precision(inv.purchase_price, precision: 2) %>
          <% else %>
            Market Execution...
          <% end %>
        </span>
      </div>
    </div>
  </td>

  <td class="px-4 py-4 text-right">
    <div class="font-mono text-slate-300"><%= number_with_delimiter(inv.amount) %></div>
    <div class="text-[9px] text-slate-500 uppercase">Cost Basis</div>
  </td>

  <td class="px-4 py-4 text-right">
    <% if inv.active? || inv.pending_sale? %>
      <div class="font-mono font-bold text-slate-100">
        ƒ<%= number_with_delimiter(inv.current_value.round(2)) %>
      </div>
    <% else %>
      <div class="font-mono text-slate-500 italic text-[11px]">Calculating...</div>
    <% end %>
  </td>

  <td class="px-4 py-4 text-right">
    <% if inv.active? || inv.pending_sale? %>
      <div class="flex flex-col items-end leading-tight">
        <span class="font-mono font-bold <%= inv.pl_dollars >= 0 ? 'text-green-400' : 'text-red-400' %>">
          <%= inv.pl_dollars >= 0 ? '+' : '-' %> ƒ<%= number_with_delimiter(inv.pl_dollars.abs.round(2)) %>
        </span>
        <span class="text-[10px] font-black px-1.5 py-0.5 rounded mt-1 <%= inv.pl_percent >= 0 ? 'bg-green-500/10 text-green-500' : 'bg-red-500/10 text-red-500' %>">
          <%= inv.pl_percent >= 0 ? '▲' : '▼' %> <%= number_to_percentage(inv.pl_percent.abs, precision: 2) %>
        </span>
      </div>
    <% else %>
      <span class="text-[10px] font-mono text-slate-500">PENDING TICK</span>
    <% end %>
  </td>

  <td class="px-4 py-4 text-right">
    <% if inv.pending_sale? %>
      <button disabled class="text-[10px] font-black tracking-widest bg-slate-900 border border-red-900/50 text-red-500/70 px-3 py-2 rounded-md cursor-not-allowed">
        SELL QUEUED
      </button>
      <div class="text-[8px] text-slate-600 mt-1 uppercase">Exiting Position</div>

    <% elsif inv.pending_purchase? %>
      <button disabled class="text-[10px] font-black tracking-widest bg-slate-900 border border-blue-900/50 text-blue-500/70 px-3 py-2 rounded-md cursor-not-allowed animate-pulse">
        BUY QUEUED
      </button>
      <div class="text-[8px] text-slate-600 mt-1 uppercase">Awaiting Price</div>

    <% elsif inv.active? %>
      <%= button_to "SELL ALL", sell_all_investments_path(ticker_id: inv.ticker.id), 
          method: :post,
          class: "text-[10px] font-black tracking-widest bg-slate-800 hover:bg-red-600 border border-slate-700 hover:border-red-500 text-slate-400 hover:text-white px-3 py-2 rounded-md transition-all duration-200 active:scale-95" %>
    <% end %>
  </td>
</tr>