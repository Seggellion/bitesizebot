
<div class=" w-full bg-slate-950 text-slate-200 font-sans flex flex-col overflow-y-auto">
  <%= render '/shared/header' %>

  <%= turbo_stream_from "market_global" %>

  <div class="flex-1 flex flex-col lg:flex-row overflow-y-auto lg:overflow-y-auto relative">
    
    <aside class="w-full lg:w-80 border-r border-slate-800 bg-slate-900/50 flex flex-col h-[75vh] z-20 shrink-0">
      <div class="p-4 border-b border-slate-800 flex justify-between items-center flex-none">
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Market Overview</h2>
        <span class="text-[10px] text-purple-400 font-bold bg-purple-500/10 px-2 py-0.5 rounded border border-purple-500/20">Sorted by Gainers</span>
      </div>
      
      <div class="flex-1 overflow-y-auto custom-scrollbar">
        <% @tickers.each do |ticker| %>
          <% is_holding = @active_ticker_ids.include?(ticker.id) %>
          
          <%= link_to root_path(symbol: ticker.symbol), 
              data: { turbo_frame: "active_market",
              turbo_action: "advance"
             }, 
              class: "block p-4 border-b border-slate-800/50 hover:bg-slate-800/40 transition group relative #{'bg-purple-500/5' if is_holding}" do %>
            
            <% if is_holding %>
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-purple-500 shadow-[0_0_8px_#a855f7]"></div>
            <% end %>

            <div class="flex justify-between items-start">
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2">
                  <span class="font-bold text-slate-100 group-hover:text-purple-400"><%= ticker.symbol %></span>
                  <% if is_holding %>
                    <span class="text-[9px] font-black bg-purple-500 text-white px-1 rounded-sm tracking-tighter uppercase">Held</span>
                  <% end %>
                </div>
                
                <% if is_holding %>
                  <% holding = @active_holdings.find { |h| h.ticker_id == ticker.id } %>
                  <div class="text-[10px] font-mono text-purple-400">Val: ƒ<%= number_with_delimiter(holding.current_value.round(1)) %></div>
                <% end %>
              </div>

              <%= render "shared/sidebar_price", ticker: ticker %>
            </div>
          <% end %>
        <% end %>
      </div>
    </aside>

    <main class="flex-1 flex flex-col h-full min-w-0 overflow-y-auto bg-slate-950 scroll-smooth">
      
      <div class="flex-none p-4 bg-slate-900/80 border-b border-slate-800 grid grid-cols-2 md:grid-cols-4 gap-4 sticky top-0 z-30 backdrop-blur-md">
        <div class="flex flex-col">
          <span class="text-[10px] text-slate-500 uppercase font-bold text-slate-400">Total Invested</span>
          <span class="text-sm font-mono font-bold">ƒ <%= number_with_delimiter(@total_invested.round(2)) %></span>
        </div>
        <div class="flex flex-col border-l border-slate-800 pl-4">
          <span class="text-[10px] text-slate-500 uppercase font-bold text-slate-400">Current Value</span>
          <span class="text-sm font-mono font-bold <%= @current_value >= @total_invested ? 'text-green-400' : 'text-red-400' %>">
            ƒ <%= number_with_delimiter(@current_value.round(2)) %>
          </span>
        </div>
        <div class="flex flex-col border-l border-slate-800 pl-4">
          <span class="text-[10px] text-slate-500 uppercase font-bold text-slate-400">ROI</span>
          <span class="text-sm font-mono font-bold <%= @current_value >= @total_invested ? 'text-green-400' : 'text-red-400' %>">
            <%= number_to_percentage(((@current_value - @total_invested) / (@total_invested.to_f > 0 ? @total_invested : 1) * 100), precision: 2) %>
          </span>
        </div>
        <div class="flex flex-col border-l border-slate-800 pl-4">
          <span class="text-[10px] text-slate-500 uppercase font-bold text-slate-400">Portfolio Health</span>
          <div class="w-full bg-slate-800 h-1.5 mt-2 rounded-full overflow-hidden">
            <div class="bg-purple-500 h-full shadow-[0_0_8px_#a855f7]" style="width: 75%"></div>
          </div>
        </div>
      </div>

      <%= turbo_frame_tag "active_market", class: "contents" do %>
        
        <div class="w-full h-[75vh] border-b border-slate-800 bg-slate-950 p-4 lg:p-6 shadow-xl z-0 flex flex-col relative">
          <%= turbo_stream_from @active_ticker %>
          
          <div class="w-full h-full">
            <%= render "shared/active_dashboard", ticker: @active_ticker %>
          </div>
        </div>

        <div class="p-4 lg:p-6 space-y-8 bg-slate-900/20 min-h-[500px]">
          
          <div data-controller="tabs" 
               data-tabs-active-class="border-purple-500 text-purple-400 border-b-2"
               data-tabs-inactive-class="text-slate-500 hover:text-slate-300">
      
             <div class="flex border-b border-slate-800 bg-slate-950/50">
               <button data-tabs-target="tab" data-tab-id="holdings" data-action="click->tabs#switch" 
                       class="px-6 py-3 text-xs font-bold uppercase tracking-wider border-purple-500 text-purple-400 border-b-2">
                 Your Holdings (<%= @active_holdings.count %>)
               </button>
               <button data-tabs-target="tab" data-tab-id="history" data-action="click->tabs#switch" 
                       class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-slate-500 hover:text-slate-300 transition">
                 Trade History
               </button>
             </div>

             <div class="bg-slate-900/20 border-x border-b border-slate-800 rounded-b-lg overflow-hidden">
               <div data-tabs-target="panel" id="holdings">
                 <table class="w-full text-left text-sm">
                   <thead class="bg-slate-900/50 text-slate-500 uppercase text-[10px] font-bold">
                     <tr>
                       <th class="px-4 py-3">Asset</th>
                       <th class="px-4 py-3 text-right">Invested</th>
                       <th class="px-4 py-3 text-right">Current Value</th>
                       <th class="px-4 py-3 text-right">P/L</th>
                       <th class="px-4 py-3"></th>
                     </tr>
                   </thead>
                   <tbody class="divide-y divide-slate-800">
                     <% if @active_holdings.any? || @pending_orders.any? %>
                         <%= render partial: "shared/portfolio_row", collection: @pending_orders, as: :inv %>
                       <%= render partial: "shared/portfolio_row", collection: @active_holdings, as: :inv %>
                     <% else %>
                       <tr>
                         <td colspan="5" class="px-4 py-8 text-center text-slate-500 text-xs uppercase tracking-widest">
                           No active holdings for <%= @active_ticker.symbol %>
                         </td>
                       </tr>
                     <% end %>
                   </tbody>
                 </table>
               </div>

               <div data-tabs-target="panel" id="history" class="hidden">
                 <table class="w-full text-left text-sm">
                   <thead class="bg-slate-900/50 text-slate-500 uppercase text-[10px] font-bold">
                     <tr>
                       <th class="px-4 py-3">Asset</th>
                       <th class="px-4 py-3">Closed Date</th>
                       <th class="px-4 py-3">Status</th>
                       <th class="px-4 py-3 text-right">Cost Basis</th>
                       <th class="px-4 py-3 text-right">Final Payout</th>
                     </tr>
                   </thead>
                   <tbody class="divide-y divide-slate-800">
                     <% if @trade_history.any? %>
                       <% @trade_history.each do |trade| %>
                         <tr class="hover:bg-slate-800/20 transition border-b border-slate-800/50">
                           <td class="px-4 py-3 font-bold text-slate-400"><%= trade.ticker.symbol %></td>
                           <td class="px-4 py-3 text-slate-500 text-xs"><%= trade.updated_at.strftime("%b %d, %H:%M") %></td>
                           <td class="px-4 py-3">
                             <span class="text-[9px] px-2 py-0.5 rounded border border-slate-700 bg-slate-800 text-slate-500 uppercase">
                               <%= trade.status %>
                             </span>
                           </td>
                           <td class="px-4 py-3 text-right font-mono text-slate-500">
                             ƒ<%= number_with_delimiter(trade.amount.round(2)) %>
                           </td>
                           <td class="px-4 py-3 text-right font-mono">
                             <div class="flex flex-col items-end">
                               <span class="text-slate-200 font-bold">ƒ<%= number_with_delimiter(trade.exit_value.round(2)) %></span>
                               <span class="text-[10px] <%= trade.total_profit >= 0 ? 'text-green-500' : 'text-red-500' %>">
                                 <%= trade.total_profit >= 0 ? '+' : '' %><%= number_with_delimiter(trade.total_profit.round(2)) %>
                               </span>
                             </div>
                           </td>
                         </tr>
                       <% end %>
                     <% else %>
                       <tr>
                         <td colspan="5" class="px-4 py-8 text-center text-slate-500 text-xs uppercase tracking-widest">
                           No trade history yet.
                         </td>
                       </tr>
                     <% end %>
                   </tbody>
                 </table>
               </div>
             </div>
          </div>
          
          <div class="bg-slate-900 border border-slate-800 rounded-xl flex flex-col h-[400px]">
             <div class="p-3 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center sticky top-0">
                 <h3 class="text-[10px] font-bold text-slate-500 uppercase">Global Order Book</h3>
                 <div class="flex items-center gap-1">
                   <span class="w-1.5 h-1.5 bg-purple-500 rounded-full animate-pulse"></span>
                   <span class="text-[10px] text-purple-400 font-bold">LIVE FEED</span>
                 </div>
             </div>

             <div class="flex-1 overflow-y-auto p-4 flex flex-col space-y-2 font-mono text-[11px]" id="ledger_entries">
                <%= turbo_stream_from "global_ledger" %>
                <% if local_assigns[:recent_ledger_entries] || defined?(@recent_ledger_entries) %>
                  <%= render partial: "Hobbit/views/shared/entry", collection: @recent_ledger_entries, as: :entry %>
                <% end %>
            </div>

          </div>

        </div> 
      <% end %> </main>
  </div>
</div>