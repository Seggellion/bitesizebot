<div class="min-h-screen bg-slate-950 text-slate-200 font-sans">
  
  <nav class="border-b border-slate-800 bg-slate-900 px-4 py-3 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-4">
      <span class="text-xl font-bold bg-gradient-to-r from-purple-400 to-pink-600 bg-clip-text text-transparent">
        SHIRE-TRADE
      </span>
      <div class="hidden md:flex items-center bg-slate-800 rounded-full px-3 py-1 border border-slate-700">
        <span class="text-xs text-slate-400 mr-2 uppercase tracking-tighter">Wallet:</span>
        <span class="text-sm font-mono text-green-400">ƒ <%= number_with_delimiter(current_user.wallet) %></span>
      </div>
    </div>

    <div class="flex items-center gap-6 text-sm font-medium">
      <%= link_to "Home", root_path, class: "hover:text-purple-400 transition" %>
      <%= link_to "Trading", "/", class: "hover:text-purple-400 transition" %>
      <%= link_to "Bingo", "/bingo-card", class: "hover:text-purple-400 transition" %>
      <%= link_to "Giveaways", "/giveaways", class: "hover:text-purple-400 transition" %>
      <div class="w-8 h-8 rounded-full border border-purple-500 overflow-hidden">
        <img src="<%= current_user.avatar %>" alt="Avatar">
      </div>
    </div>
  </nav>

  <div class="flex flex-col lg:flex-row">
    
    <aside class="w-full lg:w-80 border-r border-slate-800 bg-slate-900/50 h-auto lg:h-[calc(100vh-64px)] overflow-y-auto">
      <div class="p-4 border-b border-slate-800">
        <h2 class="text-xs font-semibold text-slate-500 uppercase tracking-widest">Market Overview</h2>
      </div>
      <% @tickers.each do |ticker| %>
        <div class="p-4 border-b border-slate-800/50 hover:bg-slate-800/40 cursor-pointer transition">
          <div class="flex justify-between items-start mb-1">
            <span class="font-bold text-slate-100"><%= ticker.symbol %></span>
            <% price_change = ticker.current_price - ticker.previous_price %>
            <span class="text-xs <%= price_change >= 0 ? 'text-green-400' : 'text-red-400' %>">
              <%= price_change >= 0 ? '▲' : '▼' %> <%= number_to_percentage((price_change / ticker.previous_price) * 100, precision: 2) %>
            </span>
          </div>
          <div class="text-lg font-mono">ƒ<%= number_with_precision(ticker.current_price, precision: 2) %></div>
          <div class="w-full bg-slate-800 h-1 mt-2 rounded-full overflow-hidden">
            <div class="bg-blue-500 h-full" style="width: <%= (ticker.liquidity / ticker.max_liquidity) * 100 %>%"></div>
          </div>
        </div>
      <% end %>
    </aside>

    <main class="flex-1 p-4 lg:p-6 overflow-y-auto">
      
      <% @tickers.each do |ticker| %>
        <section class="mb-10">
          <div class="flex flex-col md:flex-row items-baseline gap-4 mb-6">
            <h1 class="text-2xl font-bold"><%= ticker.name %> / <span class="text-slate-500">CREDIT</span></h1>
            <span class="px-2 py-0.5 bg-slate-800 rounded text-xs text-slate-400 uppercase tracking-widest">Live Feed</span>
          </div>

          <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            
            <div class="xl:col-span-2 bg-slate-900 border border-slate-800 rounded-xl p-4 shadow-xl">
              <div class="flex justify-between items-center mb-4">
                <h3 class="text-sm font-semibold text-slate-400 uppercase">Price Action</h3>
                <div class="flex gap-2">
                  <span class="w-3 h-3 rounded-full bg-red-500/20 border border-red-500/50 animate-pulse"></span>
                </div>
              </div>
              <div class="h-[400px] w-full">
                <canvas
                  data-controller="candlestick"
                  data-candlestick-data-value="<%= ticker.candlestick_data.to_json %>">
                </canvas>
              </div>
            </div>

            <div class="flex flex-col gap-6">
              <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
                <h3 class="text-xs font-semibold text-slate-500 uppercase mb-4 text-center">Market Sentiment</h3>
                <div class="flex justify-between mb-2 text-xs font-mono">
                  <span class="text-green-400">BUY <%= ticker.buy_pressure %>%</span>
                  <span class="text-red-400">SELL <%= ticker.sell_pressure %>%</span>
                </div>
                <div class="flex h-4 w-full rounded-full overflow-hidden border border-slate-700">
                  <div class="bg-green-500 shadow-[0_0_10px_rgba(34,197,94,0.5)]" style="width: <%= ticker.buy_pressure %>%"></div>
                  <div class="bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.5)]" style="width: <%= ticker.sell_pressure %>%"></div>
                </div>
              </div>

              <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
                <h3 class="text-xs font-semibold text-slate-500 uppercase mb-4">24h Performance</h3>
                <%= line_chart ticker.chart_data,
                      prefix: "ƒ",
                      height: "140px",
                      library: {
                        backgroundColor: "transparent",
                        scales: { x: { display: false }, y: { grid: { color: "#1e293b" }, ticks: { color: "#64748b", font: { size: 10 } } } }
                      }
                %>
              </div>

              <div class="bg-slate-900 border border-slate-800 rounded-xl p-4">
                 <h3 class="text-xs font-semibold text-slate-500 uppercase mb-4">Volume (f)</h3>
                 <%= column_chart ticker.volume_data,
                      height: "120px",
                      library: {
                        backgroundColor: "transparent",
                        colors: ["#3b82f6"],
                        scales: { x: { display: false }, y: { display: false } }
                      }
                 %>
              </div>
            </div>

          </div>
        </section>
      <% end %>
    </main>
  </div>
</div>