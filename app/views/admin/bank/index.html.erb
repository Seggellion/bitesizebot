<div class="p-8 bg-gray-900 min-h-screen text-white">
  <h1 class="text-3xl font-bold mb-8">Stream Economy Command Center</h1>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
      <p class="text-gray-400 text-sm uppercase">Total Liquid Supply</p>
      <p class="text-3xl font-mono text-green-400"><%= number_with_delimiter(@total_supply) %></p>
    </div>
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
      <p class="text-gray-400 text-sm uppercase">Investment Liability</p>
      <p class="text-3xl font-mono text-yellow-400"><%= number_with_delimiter(@investment_liability) %></p>
    </div>
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
      <p class="text-gray-400 text-sm uppercase">24h Inflow (Earned)</p>
      <p class="text-3xl font-mono text-blue-400">+<%= number_with_delimiter(@points_earned_24h) %></p>
    </div>
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700">
      <p class="text-gray-400 text-sm uppercase">24h Outflow (Spent)</p>
      <p class="text-3xl font-mono text-red-400">-<%= number_with_delimiter(@points_spent_24h) %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 bg-gray-800 rounded-xl p-6 border border-gray-700">
      <h2 class="text-xl font-semibold mb-4">Live Ledger Feed</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="text-gray-400 border-b border-gray-700">
              <th class="pb-3">User</th>
              <th class="pb-3">Amount</th>
              <th class="pb-3">Type</th>
              <th class="pb-3">Time</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% @recent_transactions.each do |entry| %>
              <tr>
                <td class="py-3 font-medium"><%= entry.user.username %></td>
                <td class="py-3 font-mono <%= entry.amount > 0 ? 'text-green-400' : 'text-red-400' %>">
                  <%= entry.amount > 0 ? "+#{entry.amount}" : entry.amount %>
                </td>
                <td class="py-3"><span class="px-2 py-1 bg-gray-700 rounded text-xs uppercase"><%= entry.entry_type %></span></td>
                <td class="py-3 text-gray-500 text-sm"><%= time_ago_in_words(entry.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

<div class="bg-gray-800 rounded-xl p-6 border border-gray-700 mb-8">
  <h2 class="text-xl font-semibold mb-4 text-blue-400">Admin: Grant Currency</h2>
  
  <%= form_with url: admin_inject_currency_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-xs uppercase text-gray-400 mb-1">Twitch Username</label>
      <%= f.text_field :username, 
          placeholder: "e.g. Seggellion", 
          class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-blue-500" %>
    </div>

    <div>
      <label class="block text-xs uppercase text-gray-400 mb-1">Amount (Negative to take)</label>
      <%= f.number_field :amount, 
          placeholder: "1000", 
          class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-blue-500" %>
    </div>

    <div>
      <label class="block text-xs uppercase text-gray-400 mb-1">Reason / Note</label>
      <%= f.text_field :reason, 
          placeholder: "Giveaway winner", 
          class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-blue-500" %>
    </div>

    <%= f.submit "Send Money", 
        class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2 rounded-lg transition duration-200 cursor-pointer" %>
  <% end %>
</div>

    <div class="bg-gray-800 rounded-xl p-6 border border-gray-700">
      <h2 class="text-xl font-semibold mb-4">Top 10 Holders (Whales)</h2>
      <ul class="space-y-4">
        <% @top_holders.each_with_index do |user, index| %>
          <li class="flex justify-between items-center">
            <span class="text-gray-400">#<%= index + 1 %> <%= user.username %></span>
            <span class="font-mono text-green-400"><%= number_with_delimiter(user.wallet) %></span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>