<div id="potential_winners_list" class="space-y-2">
  <% potential_winners = bingo_game.bingo_cards.select { |card| card.verify_win && !card.won? } %>
  
  <% if potential_winners.any? %>
    <% potential_winners.each do |card| %>
      <div class="p-2 bg-yellow-50 border border-yellow-200 rounded text-sm font-medium text-yellow-800 animate-bounce">
        ⚠️ <%= card.user.username %> (Ready to Bingo!)
      </div>
    <% end %>
  <% else %>
    <p class="text-gray-400 text-sm italic text-center py-2">No potential winners yet.</p>
  <% end %>
</div>