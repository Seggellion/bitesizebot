<div class="p-6 bg-gray-100 min-h-screen">
  <header class="mb-8 flex justify-between items-end">
    <div>
      <%= link_to "← Back to Dashboard", admin_bingo_games_path, class: "text-blue-600 font-bold text-sm hover:underline" %>
      <h1 class="text-3xl font-black text-gray-800 tracking-tight mt-2">Edit: <%= @bingo_game.title %></h1>
    </div>
    <div class="flex gap-2">
       <span class="px-3 py-1 bg-gray-200 text-gray-700 rounded-full text-xs font-bold uppercase tracking-widest">
        <%= @bingo_game.status %>
      </span>
    </div>
  </header>

  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 lg:col-span-8 bg-white p-8 rounded-xl shadow-lg border border-gray-100">
      <%= render "form", bingo_game: @bingo_game %>
    </div>

    <div class="col-span-12 lg:col-span-4 space-y-6">
      <% if @bingo_game.winner %>
        <div class="bg-yellow-50 border-2 border-yellow-200 p-6 rounded-xl">
          <h3 class="text-yellow-800 font-black uppercase text-xs mb-2">Game Winner</h3>
          <p class="text-2xl font-bold text-yellow-900"><%= @bingo_game.winner.username %></p>
          <p class="text-xs text-yellow-700 mt-1">Won at: <%= @bingo_game.ended_at&.strftime("%H:%M %p") %></p>
        </div>
      <% end %>

      <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100">
        <h3 class="text-gray-500 font-black uppercase text-xs mb-4">Quick Stats</h3>
        <div class="space-y-4">
          <div>
            <p class="text-sm text-gray-500">Participants</p>
            <p class="text-xl font-bold"><%= @bingo_game.bingo_cards.count %></p>
          </div>
          <div>
            <p class="text-sm text-gray-500">Created</p>
            <p class="text-md font-medium"><%= @bingo_game.created_at.strftime("%B %d, %Y") %></p>
          </div>
        </div>
      </div>
      
      <%= button_to "Delete Game", admin_bingo_game_path(@bingo_game), 
          method: :delete, 
          data: { turbo_confirm: "Are you absolutely sure? This will delete all cards and progress." }, 
          class: "w-full py-3 text-red-600 font-bold hover:bg-red-50 rounded-lg transition-colors border border-transparent hover:border-red-200" %>
    </div>
  </div>
</div>