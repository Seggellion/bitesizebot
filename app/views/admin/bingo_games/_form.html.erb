<%# app/views/admin/bingo_games/_form.html.erb %>
<%= form_with model: [:admin, bingo_game], local: true, class: "space-y-6" do |f| %>
  <% if bingo_game.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-4">
      <p class="text-red-700 font-bold">Please correct the following errors:</p>
      <ul class="list-disc ml-5 text-red-600 text-sm">
        <% bingo_game.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Game Title", class: "block text-sm font-bold text-gray-700 uppercase tracking-wide" %>
    <%= f.text_field :title, placeholder: "e.g., Friday Night Community Bingo", 
        class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-lg py-3" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :size, "Grid Size (e.g. 5 for 5x5)", class: "block text-sm font-bold text-gray-700 uppercase tracking-wide" %>
      <%= f.number_field :size, class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :status, "Game Status", class: "block text-sm font-bold text-gray-700 uppercase tracking-wide" %>
      <%= f.select :status, 
          [ ['Invite (Joinable)', 'invite'], ['Pending (Hidden)', 'pending'], ['Active (Live)', 'active'], ['Ended', 'ended']], 
          {}, 
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="flex items-center justify-between pt-6 border-t border-gray-100">
    <%= link_to "Cancel", admin_bingo_games_path, class: "text-gray-500 hover:text-gray-700 font-medium" %>
    <%= f.submit (bingo_game.new_record? ? "Create Bingo Game" : "Update Game Settings"), 
        class: "bg-blue-600 text-white px-8 py-3 rounded-xl font-black shadow-md hover:bg-blue-700 transition-all active:scale-95 cursor-pointer" %>
  </div>
<% end %>