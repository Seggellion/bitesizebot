<div class="grid grid-cols-5 gap-0.5" id='<%= "mini_card_#{card.id}" %>' >
  <% 
     # 1. Get the source of truth (Column-Major: B1-B5, I1-I5...)
     source_cells = card.cells_for_grid 
     grid_size = 5 # Assuming mini cards are always standard 5x5
  %>

  <%# 2. Loop Row-by-Row (visual order) %>
  <% (0...grid_size).each do |row_idx| %>
    <% (0...grid_size).each do |col_idx| %>
      
      <%# 3. Calculate index: (Column * Size) + Row %>
      <% cell = source_cells[(col_idx * grid_size) + row_idx] %>
      
      <% if cell %>
        <% is_pending = PendingAction.where(target: cell, status: 'pending').exists? %>
        
        <div class="h-2 w-2 rounded-sm 
          <%= cell.is_marked ? 'bg-blue-600' : 'bg-gray-200' %> 
          <%= 'animate-pulse bg-orange-400' if is_pending %>"
          title="<%= cell.coordinate %>">
        </div>
      <% end %>

    <% end %>
  <% end %>
</div>