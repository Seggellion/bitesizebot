
<div data-controller="overlay-notification" 
     class="overlay-notification absolute top-10 right-10 bg-black/80 text-white p-4 rounded-lg border-2 border-yellow-500 shadow-lg transition-opacity duration-500">
  <div class="flex items-center gap-3">
    <strong class="text-yellow-400">@<%= user.username %></strong>
    <span>marked</span>
    <b class="bg-yellow-600 px-2 rounded"><%= cell.coordinate %></b>
  </div>
  <div class="text-sm italic text-gray-300">
    "<%= cell.bingo_item.content %>"
  </div>
</div>

