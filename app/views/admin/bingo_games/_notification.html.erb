<div data-controller="overlay-notification" 
     class="overlay-notification absolute top-10 right-10 
            bg-black/90 text-white 
            p-8 rounded-2xl border-4 border-yellow-500 shadow-2xl 
            transition-opacity duration-500
            min-w-[400px] max-w-xl">
  
  <div class="flex items-center gap-6 mb-2">
    <strong class="text-3xl text-yellow-400">@<%= user.username %></strong>
    <span class="text-xl">marked</span>
    <b class="bg-yellow-600 px-4 py-1 rounded-md text-2xl">
      <%= cell.coordinate %>
    </b>
  </div>

  <div class="text-xl italic text-gray-200 mt-2">
    "<%= cell.bingo_item.content %>"
  </div>
</div>