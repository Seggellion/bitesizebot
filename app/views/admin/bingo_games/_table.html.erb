<%# app/views/admin/bingo_games/_table.html.erb %>
<table class="min-w-full bg-white border">
  <thead>
    <tr class="bg-gray-50">
      <th class="py-2 px-4 border text-left">Status</th>
      <th class="py-2 px-4 border text-left">Players</th>
      <th class="py-2 px-4 border text-left">Title</th>
      <th class="py-2 px-4 border text-left">Host</th>
      <th class="py-2 px-4 border text-left">Date</th>
      <th class="py-2 px-4 border text-left">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% games.each do |bingo_game| %>
      <tr>
        <td class="py-2 px-4 border">
          <span class="px-2 py-1 rounded text-xs <%= bingo_game.status == 'active' ? 'bg-green-100 text-green-800' : 'bg-gray-100' %>">
            <%= bingo_game.status.capitalize %>
          </span>
        </td>
        <td class="py-2 px-4 border"><%= bingo_game.bingo_cards.count %></td>
        <td class="py-2 px-4 border font-medium"><%= bingo_game.title %></td>
        <td class="py-2 px-4 border"><%= bingo_game.host&.first_name || 'N/A' %></td>
        <td class="py-2 px-4 border text-sm text-gray-600"><%= bingo_game.created_at.strftime('%Y-%m-%d') %></td>
        <td class="py-2 px-4 border">
          <div class="flex space-x-2">
            <%= link_to 'Edit', edit_admin_bingo_game_path(bingo_game), class: 'text-blue-500 hover:underline' %>
            <%= button_to 'Delete', admin_bingo_game_path(bingo_game), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>