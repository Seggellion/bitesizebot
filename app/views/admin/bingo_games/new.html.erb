<div class="p-6 bg-gray-100 min-h-screen">
  <header class="mb-8">
    <%= link_to "← Back to Dashboard", admin_bingo_games_path, class: "text-blue-600 font-bold text-sm hover:underline" %>
    <h1 class="text-3xl font-black text-gray-800 tracking-tight mt-2">Initialize New Bingo Session</h1>
  </header>

  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 lg:col-span-8 bg-white p-8 rounded-xl shadow-lg border border-gray-100">
      <%= render "form", bingo_game: @bingo_game %>
    </div>

    <div class="col-span-12 lg:col-span-4 space-y-6">
      <div class="bg-gradient-to-br from-blue-600 to-indigo-700 p-6 rounded-xl shadow-lg text-white">
        <h3 class="font-black uppercase text-xs opacity-80 mb-2">Game Setup Tips</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex gap-2"><strong>1.</strong> Set to "Invite" to let players join via Twitch.</li>
          <li class="flex gap-2"><strong>2.</strong> Switch to "Active" once you start the stream content.</li>
          <li class="flex gap-2"><strong>3.</strong> Ensure your item pool has enough items for the grid size.</li>
        </ul>
      </div>
    </div>
  </div>
</div>