<%# app/views/admin/dashboard/index.html.erb %>

<div class="p-6 bg-gray-100 min-h-screen <%= 'highlight-pending' if @claimed_winner.present? %>">
  
  <header class="mb-8 flex justify-between items-center">
    <h1 class="text-3xl font-bold text-gray-800">Admin Command Center</h1>
    <%= link_to 'OBS Overlay', obs_overlay_path, class: 'bg-purple-600 text-white px-4 py-2 rounded shadow hover:bg-purple-700' %>
  </header>

  <div class="grid grid-cols-12 gap-6">
    
    <div class="col-span-12 lg:col-span-4 bg-white p-4 rounded shadow border-l-4 border-blue-500">
      <h3 class="text-sm font-semibold text-gray-500 uppercase">Most Frequent Player</h3>
      <p class="text-2xl font-bold"><%= @most_frequent_player&.username || "N/A" %></p>
    </div>

    <div class="col-span-12 lg:col-span-4 bg-white p-4 rounded shadow border-l-4 border-green-500">
      <h3 class="text-sm font-semibold text-gray-500 uppercase">Total All-Time Participants</h3>
      <p class="text-2xl font-bold text-green-600"><%= @total_participants %></p>
    </div>

    <div class="col-span-12 lg:col-span-4 bg-white p-4 rounded shadow border-l-4 border-indigo-500">
      <h3 class="text-sm font-semibold text-gray-500 uppercase">Total Games Created</h3>
      <p class="text-2xl font-bold text-indigo-600"><%= @total_games %></p>
    </div>

<div id="pending-actions-section" class="col-span-12 lg:col-span-8 bg-white rounded-xl shadow-lg border border-gray-100 transition-all duration-500 overflow-hidden">
  
  <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-3">
      <h2 class="text-xl font-extrabold text-gray-800 tracking-tight">Pending Approvals</h2>
      <span class="bg-gray-200 text-gray-700 text-xs font-bold px-2.5 py-1 rounded-full">
        <%= @actions.count %> Requests
      </span>
      
      <% if @claimed_winner.present? %>
        <div class="flex items-center gap-2 bg-red-50 border border-red-200 px-3 py-1 rounded-lg">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-600"></span>
          </span>
          <span class="text-red-700 text-xs font-black uppercase tracking-tighter">Win Claimed</span>
        </div>
      <% end %>
    </div>

    <% if @actions.any? %>
      <div class="flex items-center gap-2">
        <%= button_to bulk_approve_admin_pending_actions_path, 
            method: :patch, 
            class: "group flex items-center gap-2 bg-white hover:bg-green-600 text-green-700 hover:text-white border border-green-200 hover:border-green-600 px-4 py-2 rounded-lg font-bold text-sm transition-all shadow-sm active:scale-95",
            data: { turbo_confirm: "Bulk approve all mark requests?" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Bulk Approve Marks
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="p-0">
    <%= turbo_stream_from "pending_actions" %>
    <table class="w-full text-left border-collapse">
      <thead class="bg-gray-50/80 text-[11px] uppercase tracking-widest text-gray-500 font-bold">
        <tr>
          <th class="py-3 px-6">User</th>
          <th class="py-3 px-6">Action Type</th>
          <th class="py-3 px-6">Details</th>
          <th class="py-3 px-6 text-right">Decision</th>
        </tr>
      </thead>
      <tbody id="pending_actions_table_body" class="divide-y divide-gray-100">
        <% if @actions.any? %>
          <% @actions.each do |action| %>
            <%= render "admin/pending_actions/pending_action", action: action %>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="py-20 text-center">
              <div class="flex flex-col items-center justify-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-3 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <p class="text-lg font-medium">All caught up!</p>
                <p class="text-sm">No pending requests at the moment.</p>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>


    <div class="col-span-12 lg:col-span-4 space-y-6">
      <div class="bg-white p-6 rounded shadow">

<% if @last_winner %>
        <h2 class="font-bold mb-3">Last Winner</h2>
            <div class="space-y-2">
                <div class="p-2 bg-yellow-50 border border-yellow-200 rounded text-sm font-medium text-yellow-800">
                    <%= @last_winner %>
                </div>
            </div>
    <% else %>

        <h2 class="font-bold mb-3">Potential Winners (Unsubmitted)</h2>
<%= turbo_stream_from "potential_winners_#{@current_game.id}" %>
  <%= render "admin/bingo_games/potential_winners", bingo_game: @current_game %>

    <% end %>


      </div>

      <div class="bg-white p-6 rounded shadow max-h-64 overflow-y-auto">
        <h2 class="font-bold mb-3">Current Participants</h2>
        <ul class="text-sm divide-y">
          <% @active_cards.each do |card| %>
            <li class="py-2 flex justify-between">
              <span><%= card.user.username %></span>
              <span class="text-gray-400"><%= card.bingo_cells.where(is_marked: true).count %> marks</span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="col-span-12 bg-white p-6 rounded shadow">
      <h2 class="text-xl font-bold mb-4">All Active Cards</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 lg:grid-cols-8 gap-4">
        <% @active_cards.each do |card| %>
          <div class="mini-card border p-2 rounded hover:border-blue-500 transition-colors cursor-pointer">
            <p class="text-xs font-bold truncate mb-1"><%= card.user.username %></p>
            <%= turbo_stream_from "bingo_game_#{@current_game.id}" %>

                <%= render "admin/bingo_games/mini_card", card: card %>

          </div>
        <% end %>
      </div>
    </div>

    <div class="col-span-12 bg-white p-6 rounded shadow">
      <h2 class="text-xl font-bold mb-4">Game History</h2>
      <%= render "admin/bingo_games/table", games: @bingo_games %>
    </div>

  </div>
</div>