<div class="p-8 bg-gray-900 min-h-screen text-white">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Stream Economy Command Center</h1>
    <span class="px-3 py-1 bg-green-900/30 text-green-400 border border-green-800 rounded-full text-xs font-semibold uppercase tracking-wider">System Active</span>
  </div>

  <%# --- STAT CARDS --- %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
      <p class="text-gray-400 text-xs uppercase font-bold tracking-wider mb-2">Total Liquid Supply</p>
      <p class="text-3xl font-mono text-green-400"><%= number_with_delimiter(@total_supply) %></p>
    </div>
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
      <p class="text-gray-400 text-xs uppercase font-bold tracking-wider mb-2">Investment Liability</p>
      <p class="text-3xl font-mono text-yellow-400"><%= number_with_delimiter(@investment_liability) %></p>
    </div>
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
      <p class="text-gray-400 text-xs uppercase font-bold tracking-wider mb-2">24h Inflow</p>
      <p class="text-3xl font-mono text-blue-400">+<%= number_with_delimiter(@points_earned_24h) %></p>
    </div>
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-lg">
      <p class="text-gray-400 text-xs uppercase font-bold tracking-wider mb-2">24h Outflow</p>
      <p class="text-3xl font-mono text-red-400">-<%= number_with_delimiter(@points_spent_24h) %></p>
    </div>
  </div>

  <%# --- MAIN CONTENT AREA --- %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
    
    <%# --- LEFT COLUMN: LEDGER FEED --- %>
    <div class="lg:col-span-2 bg-gray-800 rounded-xl border border-gray-700 shadow-xl overflow-hidden">
      <div class="p-6 border-b border-gray-700 flex justify-between items-center">
        <h2 class="text-xl font-semibold">Live Ledger Feed</h2>
        <span class="text-xs text-gray-500">Showing last 20 transactions</span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="text-gray-400 bg-gray-900/50 text-xs uppercase tracking-wider">
              <th class="px-6 py-4">User</th>
              <th class="px-6 py-4 text-right">Amount</th>
              <th class="px-6 py-4 text-center">Type</th>
              <th class="px-6 py-4">Time</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-700">
            <% @recent_transactions.each do |entry| %>
              <tr class="hover:bg-gray-700/30 transition-colors">
                <td class="px-6 py-4 font-medium"><%= entry.user.username %></td>
                <td class="px-6 py-4 font-mono text-right <%= entry.amount > 0 ? 'text-green-400' : 'text-red-400' %>">
                  <%= entry.amount > 0 ? "+#{number_with_delimiter(entry.amount)}" : number_with_delimiter(entry.amount) %>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="px-2 py-1 bg-gray-900 text-gray-400 rounded text-[10px] font-bold uppercase border border-gray-700">
                    <%= entry.entry_type %>
                  </span>
                </td>
                <td class="px-6 py-4 text-gray-500 text-sm italic"><%= time_ago_in_words(entry.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <%# --- RIGHT COLUMN: ADMIN SIDEBAR --- %>
    <div class="space-y-6">
      
      <%# MASS GRANT SQUARE %>
      <div class="bg-gray-800 rounded-xl p-6 border border-purple-500/30 shadow-xl relative overflow-hidden">
        <div class="absolute top-0 right-0 p-2 opacity-10">
           <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"></path></svg>
        </div>
        <h2 class="text-lg font-bold mb-4 text-purple-400">Mass Grant: Active Users</h2>
        
        <%= form_with url: mass_grant_admin_coffer_index_path, method: :post, class: "space-y-4" do |f| %>
          <div>
            <%= f.number_field :amount, placeholder: "Amount per user", required: true,
                class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white focus:ring-2 focus:ring-purple-500 focus:outline-none transition" %>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <% [5, 10, 15, 20].each do |mins| %>
              <%= f.button type: :submit, name: :minutes, value: mins, 
                  class: "bg-gray-700 hover:bg-purple-600 text-white py-2 rounded-lg transition text-xs font-bold" do %>
                <%= mins %>m window
              <% end %>
            <% end %>
          </div>
          <p class="text-[10px] text-gray-500 italic">Targeting users active in the selected timeframe.</p>
        <% end %>
      </div>

      <%# SINGLE GRANT SQUARE %>
      <div class="bg-gray-800 rounded-xl p-6 border border-blue-500/30 shadow-xl">
        <h2 class="text-lg font-bold mb-4 text-blue-400">Manual Injection</h2>
        <%= form_with url: inject_currency_admin_coffer_index_path, method: :post, class: "space-y-4" do |f| %>
          <%= f.text_field :username, placeholder: "Twitch Username", 
              class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          <%= f.number_field :amount, placeholder: "Amount", 
              class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          <%= f.text_field :reason, placeholder: "Reason (Internal)", 
              class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
          <%= f.submit "Process Injection", 
              class: "w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-2 rounded-lg transition cursor-pointer text-sm" %>
        <% end %>
      </div>

      <%# WHALES LIST %>
      <div class="bg-gray-800 rounded-xl p-6 border border-gray-700 shadow-xl">
        <h2 class="text-lg font-bold mb-4 text-green-400 flex items-center">
          <span class="mr-2">Top 10 Holders</span>
          <span class="text-[10px] bg-green-900/50 px-2 py-0.5 rounded border border-green-700 text-green-300">Whales</span>
        </h2>
        <ul class="space-y-3">
          <% @top_holders.each_with_index do |user, index| %>
            <li class="flex justify-between items-center text-sm border-b border-gray-700/50 pb-2 last:border-0">
              <span class="text-gray-400 font-medium">
                <span class="w-5 inline-block text-gray-600">#<%= index + 1 %></span> <%= user.username %>
              </span>
              <span class="font-mono text-green-400 font-semibold"><%= number_with_delimiter(user.wallet) %></span>
            </li>
          <% end %>
        </ul>
      </div>

    </div> <%# End Sidebar %>
  </div>
</div>