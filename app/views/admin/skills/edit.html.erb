<h1 class="text-3xl font-bold mb-4">Edit skill</h1>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <!-- Main Content Area -->
  <div class="lg:col-span-2 bg-white p-6 rounded shadow">
 <%= render 'form', skill: @skill %>

    
  <div class="bg-white p-6 rounded shadow mt-6">
    <%= form_with model: [:admin, @skill], local: true, data: { turbo: true } do |form| %>
      <div class="mb-4">
      <%= form.label :meta_description, 'Meta Description', class: 'block text-gray-700' %>
      <%= form.text_area :meta_description, class: 'form-input mt-1 block w-full' %>
      </div>
      <div class="mb-4">
      <%= form.label :meta_keywords, 'Meta Keywords', class: 'block text-gray-700' %>
      <%= form.text_area :meta_keywords, class: 'form-input mt-1 block w-full' %>
      </div>

          <div class="mb-4">
      <%= form.label :slug, "Slug", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :slug, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm" %>
    </div>


    <% end %>
  </div>



  </div>



  <!-- Sidebar -->
  <div class="space-y-4">
    <!-- Publish Box -->
    <div class="bg-white p-6 rounded shadow">
      <h2 class="text-xl font-semibold mb-4">Publish</h2>
      <div class="mb-4">

      <% unless @skill.published? %>
      <%= button_tag "Save Draft", type: "submit", form: "skillForm", class: "bg-blue-500 text-white px-4 py-2 rounded w-full" %>
      <% else %>
            <%= button_tag "Save Live", type: "submit", form: "skillForm", class: "bg-blue-500 text-white px-4 py-2 rounded w-full" %>
      <% end %>
      </div>
      <div class="mb-4">
        <span class="block text-sm text-gray-700">Status: <strong>Draft</strong></span>
        <span class="block text-sm text-gray-700">Visibility: <strong>Public</strong></span>
        <span class="block text-sm text-gray-700">Published: <strong><%= @skill.created_at %></strong></span>
      </div>
      <div class="mb-4 flex justify-end">

      <% unless @skill.published? %>
        <%= button_to "Publish", publish_admin_skill_path(@skill), method: :patch, class: "bg-blue-500 text-white px-4 py-2 rounded" %>
      <% else %>
        <%= button_to "Unpublish", unpublish_admin_skill_path(@skill), method: :patch, class: "bg-red-500 text-white px-4 py-2 rounded" %>
      <% end %>

      </div>
    </div>

    <!-- Categories Box -->
    <div class="bg-white p-6 rounded shadow" data-model-id="<%= @skill.id %>" data-model-name="skill" data-controller="category-selector">
      <h2 class="text-xl font-semibold mb-4">Categories</h2>
      <div>
        <label class="block text-sm font-medium text-gray-700" for="category-select">Select Category</label>
        <select id="category-select" name="category_id" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" data-category-selector-target="select">
          <option value="">Select a category</option>
          <% Category.all.each do |category| %>
            <option value="<%= category.id %>" <%= 'selected' if @skill.category_id == category.id %>><%= category.name %></option>
          <% end %>
        </select>
      </div>
    </div>


    <!-- Templates Box -->
    <div class="bg-white p-6 rounded shadow" data-model-id="<%= @skill.id %>" data-model-name="skill" data-controller="template-selector">
      <h2 class="text-xl font-semibold mb-4">Templates</h2>
      <div>
        <%= form_with(model: [:admin, @skill], local: true) do |form| %>
            <%= form.label :template, class: 'block text-gray-700' %>
            <%= form.select :template, options_for_select(template_options, @skill.template), include_blank: true, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm' %>

            <div class="mb-4 flex justify-end">
            <%= form.submit "Save", class: "bg-blue-500 text-white px-4 py-2 rounded cursor-pointer" %>
          </div>

        <% end %>
      </div>
    </div>

    <!-- Featured Image Box -->
    <div class="bg-white p-6 rounded shadow">
      <h2 class="text-xl font-semibold mb-4">Featured Image</h2>

      <div class="flex items-center mb-2">


<% if @skill.image.attached? %>
  <%= image_tag url_for(@skill.image), class: "w-32 h-32 object-cover" %>
          <label class="ml-4">
     
            <%= button_to "Remove", admin_skill_remove_skill_image_path(@skill, image.signed_id), 
          method: :delete, 
          data: { turbo_confirm: "Are you sure?" }, 
          class: "ml-4 bg-red-500 text-white px-3 py-1 rounded text-sm" %>
        </label>

<% else %>
  <p class="text-sm text-gray-500">No image uploaded</p>
<% end %>



      </div>

<%= form_with model: [:admin, @skill], local: true, html: { multipart: true } do |form| %>
  <div class="mb-4">
    <%= form.label :image, "Existing Images", class: "block text-sm font-medium text-gray-700" %>
    
  </div>
  <div class="mb-4">
    <%= form.label :image, "Upload New Images", class: "block text-sm font-medium text-gray-700" %>
    <%= form.file_field :image, multiple: true, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <div class="mb-4 flex justify-end">
    <%= form.submit "Upload", class: "bg-blue-500 text-white px-4 py-2 rounded cursor-pointer" %>
  </div>
<% end %>

    </div>


  </div>
</div>
