<div class="bg-white p-6 rounded shadow" data-controller="bingo-selector">
  <%= form_with model: [:admin, @bingo_game, @bingo_item] do |f| %>
    <div class="mb-4">
      <%= f.label :content, "Phrase", class: "block text-sm font-medium" %>
      <%= f.text_field :content, class: "mt-1 block w-full rounded-md border-gray-300" %>
    </div>

    <div class="grid grid-cols-2 gap-4">

  <div class="mb-4">
    <%= f.label :column_letter, "Bingo Column", class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :column_letter, ["B", "I", "N", "G", "O"], 
        { include_blank: "Select Column" }, 
        { class: "mt-1 block w-full rounded-md border-gray-300", 
          data: { bingo_selector_target: "column", action: "change->bingo-selector#updateRows" } } %>
  </div>

  <div class="mb-4">
    <%= f.label :row_number, "Row Number", class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :row_number, [], 
        {}, 
        { class: "mt-1 block w-full rounded-md border-gray-300 disabled:bg-gray-100", 
          data: { bingo_selector_target: "row" } } %>
  </div>

    </div>

    <%= f.submit "Save Item", class: "mt-4 bg-blue-500 text-white px-4 py-2 rounded" %>
  <% end %>
</div>