<div class="bg-white p-6 rounded shadow">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-bold">Bingo Items</h1>
    <%= link_to 'Add New', new_admin_bingo_item_path, class: 'bg-blue-500 text-white px-4 py-2 rounded' %>
  </div>

  <table class="min-w-full bg-white mt-4 border">
    <thead>
      <tr>
        <th class="py-2 px-4 border">Title</th>
        <th class="py-2 px-4 border">Column row</th>
        <th class="py-2 px-4 border">Date</th>
      </tr>
    </thead>
    <tbody>
      <% @bingo_items.each do |bingo_item| %>
        <tr>
          <td class="py-2 px-4 border"><%= bingo_item.content %></td>
          <td class="py-2 px-4 border"><%= bingo_item.column_letter %><%= bingo_item.row_number %></td>
          <td class="py-2 px-4 border"><%#= bingo_item.created_at.strftime('%Y-%m-%d') %></td>
          <td class="py-2 px-4 border">
            <%= link_to 'Edit', edit_admin_bingo_item_path(bingo_item), class: 'text-blue-500 hover:underline' %> |
            <%= link_to 'Delete', admin_bingo_item_path(bingo_item), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
