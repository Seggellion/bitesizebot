<div class="min-h-screen bg-gray-900 text-gray-300 font-sans p-6">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 border-b border-gray-700 pb-6">
    <div class="flex items-center space-x-4">
      <div class="relative">
        <% if @user.avatar.present? %>
          <img src="<%= @user.avatar %>" alt="Avatar" class="w-16 h-16 rounded-full border-2 border-blue-500 shadow-lg shadow-blue-500/20">
        <% else %>
          <div class="w-16 h-16 rounded-full border-2 border-gray-600 bg-gray-800 flex items-center justify-center text-xl font-bold text-gray-500">
            <%= @user.username[0..1].upcase %>
          </div>
        <% end %>
        <span class="absolute bottom-0 right-0 w-4 h-4 rounded-full border-2 border-gray-900 <%= @user.last_login > 10.minutes.ago ? 'bg-green-500' : 'bg-gray-500' %>"></span>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-white flex items-center gap-2">
          <%= @user.username %>
          <% if @user.user_type == 'admin' %>
            <span class="px-2 py-0.5 rounded text-xs font-medium bg-red-900 text-red-200 border border-red-700">ADMIN</span>
          <% end %>
        </h1>
        <div class="text-sm text-gray-500 flex flex-wrap gap-3 mt-1">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>
            <%= @user.uid %>
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <%= @user.country.presence || "Unknown" %> (<%= @user.ip_address %>)
          </span>
          <span class="flex items-center gap-1" title="Last Login">
             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             <%= time_ago_in_words(@user.last_login) if @user.last_login %> ago
          </span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4 md:mt-0 w-full md:w-auto">
      <div class="bg-gray-800 p-3 rounded-lg border border-gray-700">
        <div class="text-xs text-gray-400 uppercase tracking-wider">Wallet</div>
        <div class="text-xl font-mono font-bold text-emerald-400"><%= number_to_currency(@user.wallet, precision: 0) %></div>
      </div>
      <div class="bg-gray-800 p-3 rounded-lg border border-gray-700">
        <div class="text-xs text-gray-400 uppercase tracking-wider">Karma</div>
        <div class="text-xl font-mono font-bold text-purple-400"><%= number_with_delimiter @user.karma %></div>
      </div>
      <div class="bg-gray-800 p-3 rounded-lg border border-gray-700">
        <div class="text-xs text-gray-400 uppercase tracking-wider">Fame</div>
        <div class="text-xl font-mono font-bold text-yellow-400"><%= number_with_delimiter @user.fame %></div>
      </div>
      <div class="bg-gray-800 p-3 rounded-lg border border-gray-700">
        <div class="text-xs text-gray-400 uppercase tracking-wider">Net Worth</div>
        <div class="text-xl font-mono font-bold text-blue-400">
          <%= number_to_currency(@user.wallet + @user.investments.sum(:amount), precision: 0) %>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-12 gap-6">

    <div class="xl:col-span-8 space-y-6">

      <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-700 flex justify-between items-center bg-gray-800/50">
          <h2 class="text-lg font-semibold text-white flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Ledger History
          </h2>
          <span class="text-xs bg-gray-700 text-gray-300 px-2 py-1 rounded-full"><%= @user.ledger_entries.count %> entries</span>
        </div>
        <div class="overflow-x-auto max-h-[500px] overflow-y-auto scrollbar-thin scrollbar-thumb-gray-600 scrollbar-track-gray-800">
          <table class="w-full text-left text-sm whitespace-nowrap">
            <thead class="bg-gray-900 text-gray-400 font-medium sticky top-0 z-10 shadow-sm">
              <tr>
                <th class="px-6 py-3">Timestamp</th>
                <th class="px-6 py-3">Type</th>
                <th class="px-6 py-3 text-right">Amount</th>
                <th class="px-6 py-3">Metadata</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-700">
              <% @user.ledger_entries.order(created_at: :desc).limit(100).each do |entry| %>
                <tr class="hover:bg-gray-700/50 transition-colors">
                  <td class="px-6 py-3 text-gray-400 font-mono text-xs">
                    <%= entry.created_at.strftime("%Y-%m-%d %H:%M:%S") %>
                  </td>
                  <td class="px-6 py-3">
                    <span class="px-2 py-0.5 rounded text-xs font-medium border
                      <%= case entry.entry_type
                          when /deposit|win|reward/ then 'bg-emerald-900/30 text-emerald-400 border-emerald-800'
                          when /withdraw|loss|purchase/ then 'bg-rose-900/30 text-rose-400 border-rose-800'
                          else 'bg-blue-900/30 text-blue-400 border-blue-800'
                          end %>">
                      <%= entry.entry_type.titleize %>
                    </span>
                  </td>
                  <td class="px-6 py-3 text-right font-mono font-medium
                    <%= entry.amount >= 0 ? 'text-emerald-400' : 'text-rose-400' %>">
                    <%= entry.amount > 0 ? "+" : "" %><%= number_with_delimiter entry.amount %>
                  </td>
                  <td class="px-6 py-3 max-w-xs truncate text-gray-500 text-xs">
                    <%= entry.metadata %>
                  </td>
                </tr>
              <% end %>
              <% if @user.ledger_entries.empty? %>
                <tr>
                  <td colspan="4" class="px-6 py-8 text-center text-gray-500 italic">No ledger activity recorded.</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-gray-800 rounded-lg shadow-lg border border-gray-700">
        <div class="px-6 py-4 border-b border-gray-700">
          <h2 class="text-lg font-semibold text-white">Active Investments</h2>
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% @user.investments.each do |investment| %>
              <div class="bg-gray-900 p-4 rounded border border-gray-700 hover:border-blue-500 transition-colors">
                <div class="flex justify-between items-start mb-2">
                  <div class="font-bold text-white"><%= investment.ticker.symbol rescue "UNK" %></div>
                  <div class="<%= investment.status == 'active' ? 'text-green-500' : 'text-gray-500' %> text-xs uppercase font-bold">
                    <%= investment.status %>
                  </div>
                </div>
                <div class="space-y-1 text-sm">
                  <div class="flex justify-between text-gray-400">
                    <span>Invested:</span>
                    <span class="text-gray-200 font-mono"><%= number_to_currency(investment.amount) %></span>
                  </div>
                  <div class="flex justify-between text-gray-400">
                    <span>Rate:</span>
                    <span class="text-blue-400 font-mono"><%= (investment.interest_rate * 100).round(2) %>%</span>
                  </div>
                </div>
              </div>
            <% end %>
            <% if @user.investments.empty? %>
              <div class="col-span-full text-center text-gray-500 py-4">No active investments.</div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="xl:col-span-4 space-y-6">

      <% if @user.pending_actions.any? %>
        <div class="bg-orange-900/20 border border-orange-700/50 rounded-lg p-4">
          <h3 class="text-orange-400 font-bold mb-3 flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            Pending Actions (<%= @user.pending_actions.count %>)
          </h3>
          <ul class="space-y-2">
            <% @user.pending_actions.limit(3).each do |action| %>
              <li class="bg-gray-900/50 p-2 rounded text-sm text-orange-200/80 border border-orange-900/30">
                <%= action.action_type.humanize %> on <%= action.target_type %> #<%= action.target_id %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="bg-gray-800 rounded-lg border border-gray-700">
        <div class="px-5 py-3 border-b border-gray-700 font-semibold text-gray-200">Engagement Profile</div>
        <div class="divide-y divide-gray-700">
          <div class="p-4 grid grid-cols-2 gap-4 text-center">
            <div>
              <div class="text-2xl font-bold text-white"><%= @user.posts.count %></div>
              <div class="text-xs text-gray-500 uppercase">Posts</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-white"><%= @user.comments.count %></div>
              <div class="text-xs text-gray-500 uppercase">Comments</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-white"><%= @user.media.count %></div>
              <div class="text-xs text-gray-500 uppercase">Media Uploads</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-white"><%= @user.pages.count %></div>
              <div class="text-xs text-gray-500 uppercase">Pages</div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-gray-800 rounded-lg border border-gray-700">
        <div class="px-5 py-3 border-b border-gray-700 font-semibold text-gray-200">Gaming Activity</div>
        <div class="p-4 space-y-4">

          <div class="flex justify-between items-center">
            <span class="text-gray-400 text-sm">Bingo Cards</span>
            <span class="text-white font-mono"><%= @user.bingo_cards.count %></span>
          </div>

          <div class="flex justify-between items-center">
            <span class="text-gray-400 text-sm">Giveaway Entries</span>
            <span class="text-white font-mono"><%= @user.giveaway_entries.sum(:tickets_count) %> tix</span>
          </div>

           <div class="flex justify-between items-center">
            <span class="text-gray-400 text-sm">Raffles Entered</span>
            <span class="text-white font-mono"><%= @user.raffle_entries.count %></span>
          </div>

          <div class="h-px bg-gray-700 my-2"></div>

          <div class="bg-gradient-to-r from-yellow-900/20 to-transparent p-3 rounded border border-yellow-900/30">
            <div class="text-xs text-yellow-500 uppercase font-bold mb-1">Total Wins</div>
            <div class="flex gap-4">
              <div class="text-center">
                <span class="block text-lg font-bold text-white"><%= BingoGame.where(winner_id: @user.id).count %></span>
                <span class="text-[10px] text-gray-400">Bingo</span>
              </div>
              <div class="text-center">
                <span class="block text-lg font-bold text-white"><%= Giveaway.where(winner_id: @user.id).count %></span>
                <span class="text-[10px] text-gray-400">Giveaways</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-gray-800 rounded-lg border border-gray-700">
        <div class="px-5 py-3 border-b border-gray-700 font-semibold text-gray-200 flex justify-between">
          <span>Achievements</span>
          <span class="text-xs bg-gray-700 px-2 py-1 rounded"><%= @user.achievements.count %></span>
        </div>
        <div class="p-4">
          <div class="flex flex-wrap gap-2">
            <% @user.achievements.order(created_at: :desc).limit(10).each do |achievement| %>
              <div class="group relative">
                <div class="w-8 h-8 rounded bg-gray-700 border border-gray-600 flex items-center justify-center text-xs hover:bg-blue-600 hover:border-blue-400 transition-colors cursor-help">
                  <%= achievement.icon.present? ? achievement.icon : achievement.name[0] %>
                </div>
                <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 w-48 bg-black text-white text-xs rounded p-2 hidden group-hover:block z-20 border border-gray-700 shadow-xl">
                  <div class="font-bold text-blue-300"><%= achievement.name %></div>
                  <div class="text-gray-400"><%= achievement.description %></div>
                  <div class="mt-1 text-yellow-500">+<%= achievement.reward_points %> pts</div>
                </div>
              </div>
            <% end %>
            <% if @user.achievements.empty? %>
              <span class="text-sm text-gray-500 italic">No achievements unlocked yet.</span>
            <% end %>
          </div>
        </div>
      </div>

      <div class="bg-gray-800 rounded-lg border border-gray-700 p-4">
        <h4 class="text-xs font-bold text-gray-500 uppercase mb-2">Technical Details</h4>
        <div class="grid grid-cols-1 gap-2 text-xs font-mono text-gray-400">
          <div class="flex justify-between">
            <span>Twitch Connected:</span>
            <span class="<%= @user.twitch_access_token.present? ? 'text-green-500' : 'text-red-500' %>">
              <%= @user.twitch_access_token.present? ? 'YES' : 'NO' %>
            </span>
          </div>
          <div class="flex justify-between">
             <span>Created:</span>
             <span><%= @user.created_at.strftime("%Y-%m-%d") %></span>
          </div>
          <div class="truncate">
             <span class="block text-gray-600">UUID</span>
             <span class="text-gray-500 select-all"><%= @user.uid %></span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>