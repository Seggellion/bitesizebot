<%# app/views/bingo_cards/show.html.erb %>
<div class="max-w-4xl mx-auto p-6">
  
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 bg-white p-6 rounded-lg shadow-sm border">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @bingo_card.user.username %>'s Card</h1>
      <p class="text-gray-500">Game: <span class="font-semibold text-gray-700"><%= @game.title %></span></p>
    </div>
    <div class="mt-4 md:mt-0 text-right">
      <span class="block text-sm text-gray-500 uppercase font-bold tracking-wider">Status</span>
      <% if @bingo_card.won? %>
        <span class="text-green-600 font-bold text-xl uppercase italic">Confirmed Winner! 🏆</span>
      <% elsif @bingo_card.verify_win %>
        <span class="text-amber-600 font-bold text-xl animate-pulse uppercase">Potential Win Detected!</span>
      <% else %>
        <span class="text-blue-600 font-bold text-xl uppercase">In Progress</span>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <div class="lg:col-span-2">
      <div class="bg-gray-800 p-4 rounded-xl shadow-2xl">
        <% sorted_cells = @bingo_card.cells_for_grid %>
        <% grid_size = @game.size %>
        <% columns = ["B", "I", "N", "G", "O"].first(grid_size) %>

        <%= turbo_stream_from @bingo_card %>

        <div class="grid grid-cols-5 gap-2">
          <%# Header Letters %>
          <% columns.each do |letter| %>
            <div class="text-center py-4 bg-gray-700 rounded text-white font-black text-2xl shadow-inner">
              <% if letter == "O" %>
                <div class="flex justify-center">
                  <%= image_tag "hobbit_hole.png", alt: "O", class: "h-8 w-8 object-contain" %>
                </div>
              <% else %>
                <%= letter %>
              <% end %>
            </div>
          <% end %>

          <% (0...grid_size).each do |row_index| %>
            <% (0...grid_size).each do |col_index| %>
              
              <% cell = sorted_cells[(col_index * grid_size) + row_index] %>

              <%= render partial: "admin/bingo_cards/cell", locals: { cell: cell } %>

            <% end %>
          <% end %>


        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-white p-6 rounded-lg shadow border">
        <h3 class="text-lg font-bold mb-4 border-b pb-2">Card Stats</h3>
        <div class="space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-500">Total Marks:</span>
            <span class="font-mono font-bold"><%= @bingo_card.bingo_cells.where(is_marked: true).count %> / 25</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Pending Actions:</span>
            <span class="font-mono font-bold text-amber-600"><%= @bingo_card.pending_actions.where(status: 'pending').count %></span>
          </div>
        </div>
      </div>

        <div class="bg-indigo-50 p-6 rounded-lg border border-indigo-200 shadow-sm">
          <h3 class="text-indigo-900 font-bold mb-2 uppercase text-xs tracking-widest">Admin Actions</h3>
          <%= link_to "Back to Dashboard", admin_bingo_games_path, class: "block w-full text-center bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 rounded transition-colors" %>
        </div>
    </div>
  </div>
</div>