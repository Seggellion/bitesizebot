<div class="bg-white p-6 rounded shadow">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Edit Bingo Card #<%= @bingo_card.id %></h1>
    <%= link_to 'Back to Cards', admin_bingo_cards_path, class: 'text-gray-500 hover:underline text-sm' %>
  </div>

  <%= form_with model: [:admin, @bingo_card] do |f| %>
    <% if @bingo_card.errors.any? %>
      <div class="mb-4 p-4 bg-red-50 text-red-700 rounded">
        <h2 class="font-bold"><%= pluralize(@bingo_card.errors.count, "error") %> prohibited this card from being saved:</h2>
        <ul class="list-disc ml-5">
          <% @bingo_card.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <%# User Selection %>
      <div class="mb-4">
        <%= f.label :user_id, "Owner (User)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :user_id, User.all, :id, 
            { prompt: "Select User" }, 
            { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" } %>
      </div>

      <%# Game Selection %>
      <div class="mb-4">
        <%= f.label :bingo_game_id, "Associated Game", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :bingo_game_id, BingoGame.all, :id, :name, 
            { prompt: "Select Game" }, 
            { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" } %>
      </div>
    </div>

<div class="mt-6 border-t pt-6">
  <div class="flex justify-between items-end mb-4">
    <div>
      <h3 class="text-lg font-semibold text-gray-800">Manage Cell Marks</h3>
      <p class="text-sm text-gray-500">
        Check a box to <span class="text-green-600 font-bold">Mark</span> a cell. Uncheck to remove a mark.
      </p>
    </div>
    
    <%# Visual Legend %>
    <div class="flex space-x-3 text-xs">
      <div class="flex items-center"><span class="w-3 h-3 bg-green-100 border border-green-500 rounded mr-1"></span> Marked</div>
      <div class="flex items-center"><span class="w-3 h-3 bg-white border border-gray-300 rounded mr-1"></span> Empty</div>
    </div>
  </div>

  <%# 5x5 Grid Container %>
  <div class="grid grid-cols-5 gap-3 max-w-xl mx-auto bg-gray-100 p-4 rounded-lg border border-gray-200">
    
    <%# 
       We use fields_for to iterate over cells. 
       CRITICAL: We must order by ID to maintain the visual grid structure (B-I-N-G-O order).
    %>
    <%= f.fields_for :bingo_cells, @bingo_card.bingo_cells.order(:id) do |cell_form| %>
      
      <%# This label acts as the clickable container for the checkbox %>
      <label class="relative group cursor-pointer">
        
        <%# Hidden Checkbox (Actual Form Input) %>
        <%= cell_form.check_box :is_marked, class: "peer sr-only" %>
        
        <%# Visual Card Representation %>
        <div class="aspect-square flex flex-col items-center justify-center p-1 border-2 rounded transition-all duration-200
                    bg-white border-gray-300 text-gray-400 hover:border-blue-400
                    peer-checked:bg-green-50 peer-checked:border-green-500 peer-checked:text-green-800">
          
          <%# Coordinate (e.g., B1) %>
          <span class="text-[10px] font-bold mb-1 opacity-70">
            <%= cell_form.object.coordinate %>
          </span>
          
          <%# Item Content %>
          <span class="text-[9px] leading-tight text-center font-medium">
            <%= cell_form.object.bingo_item.content.truncate(12) %>
          </span>

          <%# Checkmark Icon (Only visible when checked) %>
          <svg class="w-4 h-4 mt-1 hidden peer-checked:block text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
      </label>
    <% end %>
  </div>
</div>
      
      <div class="flex items-center space-x-4">
        <%= f.submit "Update Card Settings", class: "bg-blue-600 text-white px-6 py-2 rounded shadow hover:bg-blue-700 cursor-pointer" %>
        <%= link_to "Cancel", admin_bingo_cards_path, class: "text-gray-600 hover:text-gray-800" %>
      </div>
    </div>
  <% end %>
</div>

<%# Optional: Cell Overview Table within Edit View %>
<div class="mt-8 bg-gray-50 p-6 rounded border border-dashed border-gray-300">
  <h3 class="text-md font-bold mb-4">Current Grid Preview (<%= @bingo_card.bingo_cells.count %> Cells)</h3>
  <div class="grid grid-cols-5 gap-2 max-w-md">
    <% @bingo_card.bingo_cells.order(:id).each do |cell| %>
      <div class="aspect-square flex items-center justify-center border text-[10px] text-center p-1 <%= cell.is_marked ? 'bg-green-200 border-green-500' : 'bg-white border-gray-200' %>">
        <%= cell.coordinate %><br>
        <%= cell.bingo_item.content.truncate(15) %>
      </div>
    <% end %>
  </div>
</div>